{
  "name": "nest-gql.glasdou",
  "version": "1.0.0",
  "description": "Nest GraphQL template",
  "author": "dr.glasdou",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write . && biome format --write .",
    "start": "portless run nest start",
    "start:dev": "portless run nest start --watch",
    "start:debug": "portless run nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:studio": "prisma studio --browser none"
  },
  "dependencies": {
    "@apollo/server": "4.12.2",
    "@nestjs/apollo": "13.1.0",
    "@nestjs/common": "11.1.6",
    "@nestjs/core": "11.1.6",
    "@nestjs/graphql": "13.1.0",
    "@nestjs/platform-express": "11.1.6",
    "@prisma/client": "6.16.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "dotenv": "17.2.2",
    "graphql": "16.11.0",
    "joi": "18.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.35.0",
    "@nestjs/cli": "11.0.10",
    "@nestjs/schematics": "11.0.7",
    "@nestjs/testing": "11.1.6",
    "@swc/cli": "0.7.8",
    "@swc/core": "1.13.5",
    "@types/express": "5.0.3",
    "@types/jest": "30.0.0",
    "@types/node": "24.5.0",
    "@types/supertest": "6.0.3",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "globals": "16.4.0",
    "jest": "30.1.3",
    "lefthook": "1.13.0",
    "portless": "^0.13.0",
    "prettier": "3.6.2",
    "prisma": "6.16.2",
    "source-map-support": "0.5.21",
    "supertest": "7.1.4",
    "ts-jest": "29.4.2",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.2",
    "typescript-eslint": "8.44.0"
  }
}